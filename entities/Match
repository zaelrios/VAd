{
  "name": "Match",
  "type": "object",
  "properties": {
    "player1_email": {
      "type": "string",
      "title": "Jugador 1 Email"
    },
    "player1_name": {
      "type": "string",
      "title": "Jugador 1"
    },
    "player2_email": {
      "type": "string",
      "title": "Jugador 2 Email"
    },
    "player2_name": {
      "type": "string",
      "title": "Jugador 2"
    },
    "skill_level": {
      "type": "string",
      "title": "Nivel",
      "enum": [
        "principiante",
        "intermedio",
        "avanzado",
        "profesional"
      ]
    },
    "play_style": {
      "type": "string",
      "title": "Modalidad",
      "enum": [
        "singles",
        "dobles"
      ]
    },
    "match_type": {
      "type": "string",
      "title": "Tipo de partido",
      "enum": [
        "amistoso",
        "competitivo"
      ],
      "default": "competitivo"
    },
    "date": {
      "type": "string",
      "title": "Fecha",
      "format": "date"
    },
    "time": {
      "type": "string",
      "title": "Hora"
    },
    "court_name": {
      "type": "string",
      "title": "Cancha"
    },
    "court_id": {
      "type": "string",
      "title": "ID Cancha"
    },
    "status": {
      "type": "string",
      "title": "Estado",
      "enum": [
        "programado",
        "en_curso",
        "pendiente_resultado",
        "completado",
        "cancelado",
        "en_disputa"
      ],
      "default": "programado"
    },
    "score": {
      "type": "string",
      "title": "Marcador"
    },
    "winner_email": {
      "type": "string",
      "title": "Ganador Email"
    },
    "player1_checkin": {
      "type": "boolean",
      "title": "Check-in J1",
      "default": false
    },
    "player2_checkin": {
      "type": "boolean",
      "title": "Check-in J2",
      "default": false
    },
    "result_reported_by": {
      "type": "string",
      "title": "Reporte por"
    }
  },
  "required": [
    "player1_email",
    "player1_name",
    "player2_email",
    "player2_name",
    "date",
    "time"
  ]
}