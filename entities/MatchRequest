{
  "name": "MatchRequest",
  "type": "object",
  "properties": {
    "player_email": {
      "type": "string",
      "title": "Email del jugador"
    },
    "player_name": {
      "type": "string",
      "title": "Nombre del jugador"
    },
    "skill_level": {
      "type": "string",
      "title": "Nivel",
      "enum": [
        "principiante",
        "intermedio",
        "avanzado",
        "profesional"
      ]
    },
    "play_style": {
      "type": "string",
      "title": "Modalidad",
      "enum": [
        "singles",
        "dobles"
      ]
    },
    "preferred_date": {
      "type": "string",
      "title": "Fecha preferida",
      "format": "date"
    },
    "preferred_time_start": {
      "type": "string",
      "title": "Hora inicio",
      "enum": [
        "06:00",
        "07:00",
        "08:00",
        "09:00",
        "10:00",
        "11:00",
        "12:00",
        "13:00",
        "14:00",
        "15:00",
        "16:00",
        "17:00",
        "18:00",
        "19:00",
        "20:00",
        "21:00",
        "22:00"
      ]
    },
    "preferred_time_end": {
      "type": "string",
      "title": "Hora fin",
      "enum": [
        "07:00",
        "08:00",
        "09:00",
        "10:00",
        "11:00",
        "12:00",
        "13:00",
        "14:00",
        "15:00",
        "16:00",
        "17:00",
        "18:00",
        "19:00",
        "20:00",
        "21:00",
        "22:00",
        "23:00"
      ]
    },
    "court_id": {
      "type": "string",
      "title": "Cancha preferida"
    },
    "court_name": {
      "type": "string",
      "title": "Nombre de cancha"
    },
    "status": {
      "type": "string",
      "title": "Estado",
      "enum": [
        "buscando",
        "emparejado",
        "cancelado"
      ],
      "default": "buscando"
    },
    "matched_with_email": {
      "type": "string",
      "title": "Emparejado con"
    },
    "matched_with_name": {
      "type": "string",
      "title": "Nombre del rival"
    },
    "match_id": {
      "type": "string",
      "title": "ID del partido"
    }
  },
  "required": [
    "player_email",
    "player_name",
    "skill_level",
    "play_style"
  ]
}