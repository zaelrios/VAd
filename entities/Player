{
  "name": "Player",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "title": "Nombre completo"
    },
    "phone": {
      "type": "string",
      "title": "Tel\u00e9fono"
    },
    "phone_verified": {
      "type": "boolean",
      "title": "Tel\u00e9fono verificado",
      "default": false
    },
    "gender": {
      "type": "string",
      "title": "G\u00e9nero",
      "enum": [
        "hombre",
        "mujer",
        "otro"
      ]
    },
    "skill_level": {
      "type": "string",
      "title": "Nivel de juego",
      "enum": [
        "principiante",
        "intermedio",
        "avanzado",
        "profesional"
      ]
    },
    "preferred_play_style": {
      "type": "string",
      "title": "Estilo de juego",
      "enum": [
        "singles",
        "dobles",
        "ambos"
      ]
    },
    "availability": {
      "type": "array",
      "title": "Disponibilidad",
      "items": {
        "type": "string",
        "enum": [
          "lunes_manana",
          "lunes_tarde",
          "lunes_noche",
          "martes_manana",
          "martes_tarde",
          "martes_noche",
          "miercoles_manana",
          "miercoles_tarde",
          "miercoles_noche",
          "jueves_manana",
          "jueves_tarde",
          "jueves_noche",
          "viernes_manana",
          "viernes_tarde",
          "viernes_noche",
          "sabado_manana",
          "sabado_tarde",
          "sabado_noche",
          "domingo_manana",
          "domingo_tarde",
          "domingo_noche"
        ]
      }
    },
    "bio": {
      "type": "string",
      "title": "Sobre m\u00ed"
    },
    "avatar_url": {
      "type": "string",
      "title": "Foto de perfil"
    },
    "matches_played": {
      "type": "number",
      "title": "Partidos jugados",
      "default": 0
    },
    "matches_won": {
      "type": "number",
      "title": "Partidos ganados",
      "default": 0
    },
    "user_email": {
      "type": "string",
      "title": "Email del usuario"
    },
    "is_registered": {
      "type": "boolean",
      "title": "Registrado",
      "default": true
    },
    "is_blocked": {
      "type": "boolean",
      "title": "Bloqueado",
      "default": false
    },
    "subscription_tier": {
      "type": "string",
      "title": "Plan",
      "enum": [
        "free",
        "premium",
        "pro"
      ],
      "default": "free"
    },
    "elo_rating": {
      "type": "number",
      "title": "Rating ELO",
      "default": 1000
    },
    "trust_stars": {
      "type": "number",
      "title": "Estrellas de Confianza",
      "default": 5.0
    },
    "consecutive_matches": {
      "type": "number",
      "title": "Racha consecutiva",
      "default": 0
    }
  },
  "required": [
    "full_name",
    "skill_level",
    "preferred_play_style",
    "user_email"
  ]
}